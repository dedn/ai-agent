# Connection settings for the local mimOE endpoint.
# Copy to .env (cp .env.example .env) and adjust if needed.
# Values come from the API button in the mimOE Studio Model View.

# Traceable router: requests show up in the Traces tab (handy for the demo).
MIMOE_BASE_URL=http://localhost:8083/mimik-airouter/openai/v1
MIMOE_API_KEY=1234
# must match the model Loaded in mimOE Studio
MIMOE_MODEL=qwen3-4b
